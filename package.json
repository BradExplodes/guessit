{
  "name": "guessit",
  "version": "1.0.0",
  "description": "Guess It! — online party game",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "node node_modules/vite/bin/vite.js --host",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "nanoid": "^5.0.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.0.10"
  }
}
